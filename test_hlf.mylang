// ============ Helpers ============
global buf of string = "                                                                                                                                                                                                                                ";
global tmpbuf of string = "                                                                                ";

def buf_clear(b of string)
    strcpy(b, "")
end

// Parse CSV field from line at position pos into dst, return new position
def csv_field(dst of string, line of string, pos of int) of int
    i = 0
    while 1 == 1 {
        c = str_get_byte(line, pos + i)
        if c == 0 then {
            str_set_byte(dst, i, 0)
            return pos + i
        }
        if c == 10 then {
            str_set_byte(dst, i, 0)
            return pos + i
        }
        if c == 13 then {
            str_set_byte(dst, i, 0)
            nxt = str_get_byte(line, pos + i + 1)
            if nxt == 10 then return pos + i + 2
            return pos + i + 1
        }
        if c == ',' then {
            str_set_byte(dst, i, 0)
            return pos + i + 1
        }
        str_set_byte(dst, i, c)
        i = i + 1
    }
end

global d0 of string = "0";
global d1 of string = "1";
global d2 of string = "2";
global d3 of string = "3";
global d4 of string = "4";
global d5 of string = "5";
global d6 of string = "6";
global d7 of string = "7";
global d8 of string = "8";
global d9 of string = "9";

def choose_digit(dst of string, d of int)
    if d == 0 then strcat(dst, d0) end
    if d == 1 then strcat(dst, d1) end
    if d == 2 then strcat(dst, d2) end
    if d == 3 then strcat(dst, d3) end
    if d == 4 then strcat(dst, d4) end
    if d == 5 then strcat(dst, d5) end
    if d == 6 then strcat(dst, d6) end
    if d == 7 then strcat(dst, d7) end
    if d == 8 then strcat(dst, d8) end
    if d == 9 then strcat(dst, d9) end
end

def int_to_str(dst of string, val of int)
    buf_clear(dst)
    if val < 0 then {
        strcat(dst, "-")
        val = 0 - val
    }
    if val >= 10 then {
        int_to_str(dst, val / 10)
    }
    choose_digit(dst, val - (val / 10) * 10)
end

// ============ CSV Loaders ============
def load_people() of int
    f = fopen("labs-examples/system-programms/lab-2/csv-data/people.csv", "r")
    if f == "" then return 1 end
    fgets(buf, 256, f)
    p_count = 0
    while feof(f) == 0 {
        fgets(buf, 256, f)
        if feof(f) != 0 then break end
        pos = 0
        pos = csv_field(tmpbuf, buf, pos)
        p_id[p_count] = atoi(tmpbuf)
        pos = csv_field(tmpbuf, buf, pos)
        p_surname[p_count] = malloc(64)
        strcpy(p_surname[p_count], tmpbuf)
        pos = csv_field(tmpbuf, buf, pos)
        p_name[p_count] = malloc(64)
        strcpy(p_name[p_count], tmpbuf)
        pos = csv_field(tmpbuf, buf, pos)
        p_patronymic[p_count] = malloc(64)
        strcpy(p_patronymic[p_count], tmpbuf)
        pos = csv_field(tmpbuf, buf, pos)
        p_birthday[p_count] = malloc(64)
        strcpy(p_birthday[p_count], tmpbuf)
        p_count = p_count + 1
    }
    fclose(f)
    return 0
end


