    q6_scan()
    return 0
end

// =============================================================
// Q7: Students with same surname, different birthdays
// =============================================================
global q7_cnt of int = 0;

def q7_scan() of int
    q7_cnt = 0
    i = 0
    while i < 31 {
        surname = p_surname[i]
        scount = 0
        j = 0
        while j < 31 {
            if strcmp(p_surname[j], surname) == 0 then {
                scount = scount + 1
            }
            j = j + 1
        }
        if scount > 1 then {
            diff = 0
            j = 0
            while j < 31 {
                if strcmp(p_surname[j], surname) == 0 then {
                    k = j + 1
                    while k < 31 {
                        if strcmp(p_surname[k], surname) == 0 then {
                            if strcmp(p_birthday[j], p_birthday[k]) != 0 then {
                                diff = 1
                                k = 31; j = 31
                            }
                        }
                        k = k + 1
                    }
                }
                j = j + 1
            }
            if diff == 1 then {
                q7_cnt = q7_cnt + 1
            }
        }
        i = i + 1
    }
    puts("=== Query 7: Same surname, different birthdays ===")
    buf_clear(buf)
    strcat(buf, "Surname groups: ")
    tmp = malloc(16)
    int_to_str(tmp, q7_cnt)
    strcat(buf, tmp)
    puts(buf)
    return 0
end

def run_q7() of int
    q7_scan()
    return 0
end
