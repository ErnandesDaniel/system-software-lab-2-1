// =============================================================
global gp_plan_id of int[14] = [101, 101, 101, 101, 102, 102, 103, 103, 103, 104, 104, 104, 105, 105];
global gp_group of string[14] = ["1100", "2100", "3100", "4100", "5100", "5200", "6100", "7100", "8100", "9100", "1101", "1201", "1301", "1401"];
global gp_dept of string[14] = ["Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С‘Р Р…РЎвЂћР С•РЎР‚Р СР В°РЎвЂ Р С‘Р С•Р Р…Р Р…РЎвЂ№РЎвЂ¦ РЎРѓР С‘РЎРѓРЎвЂљР ВµР С", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С‘Р Р…РЎвЂћР С•РЎР‚Р СР В°РЎвЂ Р С‘Р С•Р Р…Р Р…РЎвЂ№РЎвЂ¦ РЎРѓР С‘РЎРѓРЎвЂљР ВµР С", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С—РЎР‚Р С‘Р С”Р В»Р В°Р Т‘Р Р…Р С•Р в„– Р СР В°РЎвЂљР ВµР СР В°РЎвЂљР С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С‘Р Р…РЎвЂћР С•РЎР‚Р СР В°РЎвЂ Р С‘Р С•Р Р…Р Р…РЎвЂ№РЎвЂ¦ РЎРѓР С‘РЎРѓРЎвЂљР ВµР С", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р Р†РЎвЂ№РЎвЂЎР С‘РЎРѓР В»Р С‘РЎвЂљР ВµР В»РЎРЉР Р…Р С•Р в„– РЎвЂљР ВµРЎвЂ¦Р Р…Р С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С—РЎР‚Р С‘Р С”Р В»Р В°Р Т‘Р Р…Р С•Р в„– Р СР В°РЎвЂљР ВµР СР В°РЎвЂљР С‘Р С”Р С‘", "Р С™Р В°РЎвЂћР ВµР Т‘РЎР‚Р В° Р С—РЎР‚Р С‘Р С”Р В»Р В°Р Т‘Р Р…Р С•Р в„– Р СР В°РЎвЂљР ВµР СР В°РЎвЂљР С‘Р С”Р С‘"];

// =============================================================
// Helpers
// =============================================================
global buf of string = "                                                                                                                                                                                                                                ";

def buf_clear(b of string)
    strcpy(b, "")
end

global d0 of string = "0";
global d1 of string = "1";
global d2 of string = "2";
global d3 of string = "3";
global d4 of string = "4";
global d5 of string = "5";
global d6 of string = "6";
global d7 of string = "7";
global d8 of string = "8";
global d9 of string = "9";

def choose_digit(dst of string, d of int)
    if d == 0 then strcat(dst, d0) end
    if d == 1 then strcat(dst, d1) end
    if d == 2 then strcat(dst, d2) end
    if d == 3 then strcat(dst, d3) end
    if d == 4 then strcat(dst, d4) end
    if d == 5 then strcat(dst, d5) end
    if d == 6 then strcat(dst, d6) end
    if d == 7 then strcat(dst, d7) end
    if d == 8 then strcat(dst, d8) end
    if d == 9 then strcat(dst, d9) end
end

def int_to_str(dst of string, val of int)
    buf_clear(dst)
    if val < 0 then {
        strcat(dst, "-")
        val = 0 - val
    }
    if val >= 10 then {
        int_to_str(dst, val / 10)
    }
    choose_digit(dst, val - (val / 10) * 10)
end

global CORO_COUNT of int = 0;

// =============================================================
// Q1: INNER JOIN tv + ved, filter tv.Р ВР вЂќ=3, person_id>153285
// =============================================================
global q1_pipe_t_ready of int = 0;
global q1_pipe_t_name of string;
global q1_pipe_t_done of int = 0;
global q1_pipe_v_ready of int = 0;
global q1_pipe_v_date of string;
global q1_pipe_v_done of int = 0;
global q1_res_dates of string[10];
global q1_res_names of string[10];
global q1_res_count of int = 0;

coroutine q1_scan_types() of int
    i = 0
    while i < 5 {
        if tv_id[i] == 3 then {
            q1_pipe_t_name = tv_name[i]
            q1_pipe_t_ready = 1
            while q1_pipe_t_ready == 1 { yield }
            i = 5
        }
        i = i + 1
    }
    q1_pipe_t_done = 1
    yield
    return 0
end

coroutine q1_scan_ved() of int
    i = 0
    while i < 36 {
        if v_type_id[i] == 3 then {
            if v_person_id[i] > 153285 then {
                q1_pipe_v_date = v_date[i]
                q1_pipe_v_ready = 1
                yield
                while q1_pipe_v_ready == 1 { yield }
            }
        }
        i = i + 1
    }
    q1_pipe_v_done = 1
    yield
    return 0
end

coroutine q1_join_output() of int
    while q1_pipe_t_ready == 0 && q1_pipe_t_done == 0 { yield }
    t_name = q1_pipe_t_name
    q1_pipe_t_ready = 0

    while q1_pipe_v_done == 0 || q1_pipe_v_ready == 1 {
        if q1_pipe_v_ready == 1 then {
            q1_res_names[q1_res_count] = t_name
            q1_res_dates[q1_res_count] = q1_pipe_v_date
            q1_res_count = q1_res_count + 1
            q1_pipe_v_ready = 0
        }
        yield
    }

    i = 0
    while i < q1_res_count {
        j = i + 1
        while j < q1_res_count {
            if strcmp(q1_res_dates[i], q1_res_dates[j]) > 0 then {
                tmp = q1_res_dates[i]
                q1_res_dates[i] = q1_res_dates[j]
                q1_res_dates[j] = tmp
                tmp_n = q1_res_names[i]
                q1_res_names[i] = q1_res_names[j]
                q1_res_names[j] = tmp_n
            }
            j = j + 1
        }
        i = i + 1
    }

    i = 0
    while i < q1_res_count {
        buf_clear(buf)
        strcat(buf, q1_res_names[i])
        strcat(buf, ", ")
        strcat(buf, q1_res_dates[i])
        puts(buf)
        i = i + 1
    }
    return 0
end

def run_q1() of int
    puts("=== Query 1: INNER JOIN ===")
    CORO_COUNT = 0
    coro_init_nasm()
    f0 = 0; f1 = 0; f2 = 0
    while f0 == 0 || f1 == 0 || f2 == 0 {
        if f0 == 0 then f0 = resume_coroutine_nasm(CORO_COUNT + 0) end
        if f1 == 0 then f1 = resume_coroutine_nasm(CORO_COUNT + 1) end
        if f2 == 0 then f2 = resume_coroutine_nasm(CORO_COUNT + 2) end
    }
    CORO_COUNT = CORO_COUNT + 3
    return 0
end

