    set_coroutine_scheduler_nasm(rr_scheduler);
    run_coroutine_runtime_nasm();
    puts("--- Q4 done ---\n");

    // ---- Q5 ----
    puts("--- Q5: Avg grades 4100 >= 1100 ---\n");
    arena_reset();
    // Compute avg1100 (sequential, not a coroutine)
    avg_buf = malloc(4);
    g_avg1100 = 0;
    group_avg("1100", avg_buf);
    g_avg1100 = avg_buf[0];
    printf("Avg 1100 = %d\n", g_avg1100);

    p_init(q5_p);
