                if o_person_id[j] == pid then {
                    if strcmp(o_form[j], "Р·Р°РѕС‡РЅР°СЏ") == 0 then {
                        if o_course[j] == 1 then {
                            q6_cnt = q6_cnt + 1
                            j = 30
                        }
                    }
                }
                j = j + 1
            }
        }
