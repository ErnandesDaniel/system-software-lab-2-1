    arena_init();

    puts("=== Lab 2: Map-Reduce Pipeline ===\n");

    // ---- Q1 ----
    puts("--- Q1: INNER JOIN (3 coroutines) ---\n");
    p_init(q1_v);
    p_init(q1_t);
    n_coros = 3;
    init_coroutine_runtime_nasm();
    create_coroutine_nasm(q1_read_ved);
    create_coroutine_nasm(q1_read_types);
    create_coroutine_nasm(q1_join_print);
    set_coroutine_scheduler_nasm(rr_scheduler);
    run_coroutine_runtime_nasm();
    puts("--- Q1 done ---\n");

    // ---- Q2 ----
    puts("--- Q2: LEFT JOIN (3 coroutines) ---\n");
