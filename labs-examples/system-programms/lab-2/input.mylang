    set_coroutine_scheduler_nasm(rr_scheduler);
    run_coroutine_runtime_nasm();
    free(avg_buf);
    puts("--- Q5 done ---\n");

    // ---- Q6 ----
    puts("--- Q6: After 2012-09-01, course 1, part-time (3 coroutines) ---\n");
    arena_reset();
    p_init(q6_sl);
    p_init(q6_st);
    n_coros = 3;
    init_coroutine_runtime_nasm();
    create_coroutine_nasm(q6_load_studies);
    create_coroutine_nasm(q6_read_students);
    create_coroutine_nasm(q6_lookup_print);
    set_coroutine_scheduler_nasm(rr_scheduler);
    run_coroutine_runtime_nasm();
    puts("--- Q6 done ---\n");

    // ---- Q7 ----
    puts("--- Q7: Same surname, diff bday (2 coroutines) ---\n");
    arena_reset();
    p_init(q7_p);
    n_coros = 2;
    init_coroutine_runtime_nasm();
    create_coroutine_nasm(q7_load_people);
    create_coroutine_nasm(q7_compare_print);
    set_coroutine_scheduler_nasm(rr_scheduler);
    run_coroutine_runtime_nasm();
    puts("--- Q7 done ---\n");

    puts("\n=== Done ===\n");
