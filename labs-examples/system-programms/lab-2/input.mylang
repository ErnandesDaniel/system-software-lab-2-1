    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        gp_pid[gp_n] = atoi(row_buf + cols[0]);
        gp_dept[gp_n] = save_col(cols[2]);
        gp_n = gp_n + 1;
    }
    fclose(f); free(cols); return gp_n;
}

// ============================================================
// Q1 Pipeline: INNER JOIN
// vedomosti.tid=3 AND vedomosti.pid>153285 JOIN types_vedomostei
// Stages: [vedomosti → filter] → [join] → print
//         [types → cache] ──────┘
// ============================================================

global q1_filt of Pipe;  // filtered vedomosti indices → join

// Stage 1: Filter vedomosti, send matching indices through pipe
def q1_stage_filter() of int {
    p_init(q1_filt);
    found = 0;
    i = 0;
    while (i < vv_n) {
        if (vv_tid[i] == 3 && vv_pid[i] > 153285) {
            p_write(q1_filt, i);
            found = found + 1;
        }
        i = i + 1;
    }
    p_write(q1_filt, -1);
    // In preemptive coroutine impl, this stage yields after each write
    return found;
}

// Stage 2: Join & print (reads from q1_filt pipe)
def q1_stage_join_print() of int {
    found = 0;
    while (true) {
        idx = p_read(q1_filt);
        if (idx == -1) { break; }
        if (idx == -2) { } else {
            // Find type name for tid=3
            ti = 0;
            while (ti < tv_n) {
                if (tv_id[ti] == 3) {
                    print_arena(tv_name[ti]);
                    putchar(44); putchar(32);
                    print_arena(vv_date[idx]);
                    putchar(10);
                    found = found + 1;
                }
                ti = ti + 1;
            }
        }
    }
    printf("Found: %d\n", found);
    return found;
}

def q1_pipeline() of int {
    puts("--- Q1: INNER JOIN ---\n");
    puts("Pipeline stages:\n");
    puts("  [vedomosti.csv] → filter(tid=3, pid>153285) → join → print\n");
    puts("  [types_vedomostei.csv] → cache ────────────────┘\n");
    q1_stage_filter();
    return q1_stage_join_print();
}

// ============================================================
// Q2 Pipeline: LEFT JOIN
// studies.pid=163276 LEFT JOIN students ON pid AND start='2008-09-01'
// ============================================================

global q2_out of Pipe;

def q2_pipeline() of int {
    puts("--- Q2: LEFT JOIN ---\n");
    puts("Pipeline: [studies] → filter(pid=163276) → left join → print\n");
    p_init(q2_out);
    found = 0;
    i = 0;
    while (i < st_n) {
        if (st_pid[i] == 163276) {
            p_write(q2_out, i);
            // Pass study pid through pipe for join
            p_write(q2_out, st_pid[i]);
        }
        i = i + 1;
    }
    p_write(q2_out, -1);
    // Stage 2: join + print
    while (true) {
        idx = p_read(q2_out);
        if (idx == -1) { break; }
        if (idx == -2) { } else {
            pid = p_read(q2_out);
            // LEFT JOIN students
            joined = 0;
            di = 0;
            while (di < sd_n) {
                if (sd_pid[di] == pid && eq_arena(sd_start[di], "2008-09-01") != 0) {
                    printf("%d, OK500, %d\n", pid, sd_pid[di]);
                    joined = 1;
                    found = found + 1;
                }
                di = di + 1;
            }
            if (joined == 0) {
                printf("%d, NULL, NULL\n", pid);
                found = found + 1;
            }
        }
    }
    printf("Found: %d\n", found);
    return found;
}

// ============================================================
// Q3: Count FCE students without patronymic
// people.patr IS NULL AND studies.fac='FCE' AND EXISTS students.pid=people.id
// ============================================================

def q3_pipeline() of int {
    puts("--- Q3: No patronymic + FCE ---\n");
    count = 0;
    pi = 0;
    while (pi < pp_n) {
        if (pp_patr[pi] == 0 || str_arena[pp_patr[pi]] == 0) {
            pid = pp_id[pi];
            si = 0;
            while (si < st_n) {
                if (st_pid[si] == pid && eq_arena(st_fac[si], "FCE") != 0) {
                    di = 0;
                    while (di < sd_n) {
                        if (sd_pid[di] == pid) {
                            count = count + 1;
                            break;
                        }
                        di = di + 1;
                    }
                    break;
                }
                si = si + 1;
            }
        }
        pi = pi + 1;
    }
    printf("Count: %d\n", count);
    return count;
}

// ============================================================
// Main
// ============================================================
def main() of int {
    row_buf = malloc(10000);
    if (row_buf == 0) { puts("malloc failed"); return 1; }
    arena_init();

    puts("=== Lab 2: Map-Reduce Pipeline ===\n");
    puts("Data files:\n");

    load_types("labs-examples/system-programms/lab-2/csv-data/types_vedomostei.csv");
    load_people("labs-examples/system-programms/lab-2/csv-data/people.csv");
    load_studies("labs-examples/system-programms/lab-2/csv-data/studies.csv");
    load_students("labs-examples/system-programms/lab-2/csv-data/students.csv");
    load_vedomosti("labs-examples/system-programms/lab-2/csv-data/vedomosti.csv");
    load_group_plans("labs-examples/system-programms/lab-2/csv-data/group_plans.csv");

    printf("Types: %d\n", tv_n);
    printf("People: %d\n", pp_n);
    printf("Studies: %d\n", st_n);
    printf("Students: %d\n", sd_n);
    printf("Vedomosti: %d\n", vv_n);
    printf("Plans: %d\n", gp_n);

    q1_pipeline();
    q2_pipeline();
    q3_pipeline();

    puts("\n=== Done ===\n");
    return 0;
}
