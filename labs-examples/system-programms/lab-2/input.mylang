// Q3: Count students Р¤РљРўРРЈ without patronymic
// =============================================================
global q3_count of int = 0;

def q3_scan() of int
    q3_count = 0
    i = 0
    while i < 31 {
        pid = p_id[i]
        if strcmp(p_patronymic[i], "") == 0 then {
            j = 0
            while j < 30 {
                if o_person_id[j] == pid then {
                    if strcmp(o_fac[j], "Р¤РљРўРРЈ") == 0 then {
                        k = 0
                        while k < 30 {
                            if st_person_id[k] == pid then {
                                q3_count = q3_count + 1
                                k = 30; j = 30
                            }
                            k = k + 1
                        }
                    }
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    puts("=== Query 3: Count Р¤РљРўРРЈ Р±РµР· РѕС‚С‡РµСЃС‚РІР° ===")
    buf_clear(buf)
    int_to_str(buf, q3_count)
    puts(buf)
    return 0
end

def run_q3() of int
    q3_scan()
    return 0
end

// =============================================================
// Q4: Plan numbers with >2 groups on Р’Рў dept
// =============================================================
global q4_plan_ids of int[10];
global q4_plan_counts of int[10];
global q4_plan_cnt of int = 0;

def q4_scan() of int
    q4_plan_cnt = 0
    i = 0
    while i < 14 {
        if strcmp(gp_dept[i], "РљР°С„РµРґСЂР° РІС‹С‡РёСЃР»РёС‚РµР»СЊРЅРѕР№ С‚РµС…РЅРёРєРё") == 0 then {
            plan = gp_plan_id[i]
            k = 0; found = 0
            while k < q4_plan_cnt {
                if q4_plan_ids[k] == plan then {
                    q4_plan_counts[k] = q4_plan_counts[k] + 1
                    found = 1
                    k = q4_plan_cnt
                }
                k = k + 1
            }
            if found == 0 then {
                q4_plan_ids[q4_plan_cnt] = plan
                q4_plan_counts[q4_plan_cnt] = 1
                q4_plan_cnt = q4_plan_cnt + 1
            }
        }
        i = i + 1
    }
    puts("=== Query 4: Plans >2 groups on Р’Рў ===")
    i = 0
    while i < q4_plan_cnt {
        if q4_plan_counts[i] > 2 then {
            buf_clear(buf)
            int_to_str(buf, q4_plan_ids[i])
            strcat(buf, ": ")
            tmp = malloc(16)
            int_to_str(tmp, q4_plan_counts[i])
            strcat(buf, tmp)
            strcat(buf, " groups")
            puts(buf)
        }
        i = i + 1
    }
    return 0
end

def run_q4() of int
    q4_scan()
    return 0
end

// =============================================================
// Q5: Average grades group 4100 >= avg of group 1100
// =============================================================
global q5_cnt of int = 0;
global q5_avg_1100 of int = 0;

def q5_scan() of int
    sum1100 = 0; cnt1100 = 0
    i = 0
    while i < 30 {
        if strcmp(st_group[i], "1100") == 0 then {
            pid = st_person_id[i]
            j = 0
            while j < 36 {
                if v_person_id[j] == pid then {
                    sum1100 = sum1100 + v_mark[j]
                    cnt1100 = cnt1100 + 1
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    if cnt1100 > 0 then q5_avg_1100 = sum1100 * 100 / cnt1100 end

    q5_cnt = 0
    i = 0
    while i < 30 {
        if strcmp(st_group[i], "4100") == 0 then {
            pid = st_person_id[i]
            sum4100 = 0; cnt4100 = 0
            j = 0
            while j < 36 {
                if v_person_id[j] == pid then {
                    sum4100 = sum4100 + v_mark[j]
                    cnt4100 = cnt4100 + 1
                }
                j = j + 1
            }
            if cnt4100 > 0 then {
                avg4100 = sum4100 * 100 / cnt4100
                if avg4100 >= q5_avg_1100 then {
                    q5_cnt = q5_cnt + 1
                }
            }
        }
        i = i + 1
    }

    puts("=== Query 5: Avg grades group 4100 >= group 1100 ===")
    buf_clear(buf)
    strcat(buf, "Avg 1100 = ")
    tmp = malloc(16)
    int_to_str(tmp, q5_avg_1100)
    strcat(buf, tmp)
    puts(buf)
    buf_clear(buf)
    strcat(buf, "Students found: ")
    int_to_str(tmp, q5_cnt)
    strcat(buf, tmp)
    puts(buf)
    return 0
end

def run_q5() of int
    q5_scan()
    return 0
end

