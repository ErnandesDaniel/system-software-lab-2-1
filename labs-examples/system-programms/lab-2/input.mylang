// Lab 2: Map-Reduce Pipeline via Pipe streams
// Data loaded into global arrays (as before), queries executed as
// pipeline stages connected by pipes, each stage being a self-contained
// procedure that receives/produces data through byte streams.
// (Stages designed as independent coroutine-friendly procedures.)
import puts;
import printf;
import putchar;
import fopen;
import fclose;
import fgetc;
import atoi;
import malloc;
import free;
import strcmp;
import strcpy;

// ============================================================
// Pipe (bounded buffer for inter-stage communication)
// ============================================================
struct Pipe { arr of int[256]; head of int; tail of int; count of int; }

def p_init(p of Pipe) {
    p.head = 0; p.tail = 0; p.count = 0;
}

def p_write(p of Pipe, v of int) of int {
    if (p.count >= 256) { return -1; }
    p.arr[p.tail] = v;
    p.tail = (p.tail + 1) % 256;
    p.count = p.count + 1;
    return 0;
}

def p_read(p of Pipe) of int {
    if (p.count <= 0) { return -2; }
    r = p.arr[p.head];
    p.head = (p.head + 1) % 256;
    p.count = p.count - 1;
    return r;
}

// Drain all remaining values from pipe
def p_drain(p of Pipe) {
    while (true) {
        if (p_read(p) == -2) { return; }
    }
}

// ============================================================
// Row buffer & string arena
// ============================================================
global row_buf of string;
global str_arena of string;
global str_apos of int;

def arena_init() {
    str_arena = malloc(30000);
    str_apos = 0;
}

// Copy row_buf column at offset into arena, return arena offset
def save_col(off of int) of int {
    start = str_apos;
    i = start;
    while (true) {
        c = row_buf[off];
        str_arena[i] = c;
        off = off + 1;
        i = i + 1;
        if (c == 0) { str_apos = i; return start; }
    }
}

def print_arena(a of int) {
    i = 0;
    while (true) {
        c = str_arena[a + i];
        if (c == 0) { break; }
        putchar(c); i = i + 1;
    }
}

def eq_arena(a of int, lit of string) of int {
    i = 0;
    while (true) {
        ac = str_arena[a + i];
        lc = lit[i];
        if (ac != lc) { return 0; }
        if (ac == 0) { return 1; }
        i = i + 1;
    }
}

def eq_arena_arena(a of int, b of int) of int {
    i = 0;
    while (true) {
        ac = str_arena[a + i];
        bc = str_arena[b + i];
        if (ac != bc) { return 0; }
        if (ac == 0) { return 1; }
        i = i + 1;
    }
}

def gt_arena(a of int, lit of string) of int {
    i = 0;
    while (true) {
        ac = str_arena[a + i];
        lc = lit[i];
        if (ac == 0 && lc == 0) { return 0; }
        if (ac == 0) { return -1; }
        if (lc == 0) { return 1; }
        if (ac != lc) { return ac - lc; }
        i = i + 1;
    }
}

// ============================================================
// CSV loaders → global arrays (same as before)
// ============================================================
def read_line(f of string) of int {
    pos = 0;
    while (true) {
        c = fgetc(f);
        if (c == -1 || c == 10) { row_buf[pos] = 0; return pos; }
        row_buf[pos] = c; pos = pos + 1;
    }
}

def parse_row(cols of string) of int {
    if (row_buf[0] == 0) { return 0; }
    n = 0;
    cols[0] = 0;
    i = 0;
    while (true) {
        c = row_buf[i];
        if (c == 0) { break; }
        if (c == 44) { row_buf[i] = 0; n = n + 1; cols[n] = i + 1; }
        i = i + 1;
    }
    return n + 1;
}

// Global data arrays
global tv_id of int[10];
global tv_name of int[10];
global tv_n of int;

global pp_id of int[100];
global pp_surname of int[100];
global pp_name of int[100];
global pp_patr of int[100];
global pp_bday of int[100];
global pp_n of int;

global st_pid of int[100];
global st_form of int[100];
global st_fac of int[100];
global st_course of int[100];
global st_n of int;

global sd_pid of int[100];
global sd_group of int[100];
global sd_start of int[100];
global sd_n of int;

global vv_tid of int[100];
global vv_pid of int[100];
global vv_mark of int[100];
global vv_date of int[100];
global vv_n of int;

global gp_pid of int[50];
global gp_dept of int[50];
global gp_n of int;

def load_types(fn of string) of int {
    f = fopen(fn, "r"); if (f == 0) { return -1; }
    read_line(f); tv_n = 0;
    cols = malloc(20);
    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        tv_id[tv_n] = atoi(row_buf + cols[0]);
        tv_name[tv_n] = save_col(cols[1]);
        tv_n = tv_n + 1;
    }
    fclose(f); free(cols); return tv_n;
}

def load_people(fn of string) of int {
    f = fopen(fn, "r"); if (f == 0) { return -1; }
    read_line(f); pp_n = 0;
    cols = malloc(20);
    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        pp_id[pp_n] = atoi(row_buf + cols[0]);
        pp_surname[pp_n] = save_col(cols[1]);
        pp_name[pp_n] = save_col(cols[2]);
        pp_patr[pp_n] = save_col(cols[3]);
        pp_bday[pp_n] = save_col(cols[4]);
        pp_n = pp_n + 1;
    }
    fclose(f); free(cols); return pp_n;
}

def load_studies(fn of string) of int {
    f = fopen(fn, "r"); if (f == 0) { return -1; }
    read_line(f); st_n = 0;
    cols = malloc(20);
    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        st_pid[st_n] = atoi(row_buf + cols[0]);
        st_form[st_n] = save_col(cols[5]);
        st_fac[st_n] = save_col(cols[6]);
        st_course[st_n] = atoi(row_buf + cols[7]);
        st_n = st_n + 1;
    }
    fclose(f); free(cols); return st_n;
}

def load_students(fn of string) of int {
    f = fopen(fn, "r"); if (f == 0) { return -1; }
    read_line(f); sd_n = 0;
    cols = malloc(20);
    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        sd_pid[sd_n] = atoi(row_buf + cols[0]);
        sd_group[sd_n] = save_col(cols[1]);
        sd_start[sd_n] = save_col(cols[2]);
        sd_n = sd_n + 1;
    }
    fclose(f); free(cols); return sd_n;
}

def load_vedomosti(fn of string) of int {
    f = fopen(fn, "r"); if (f == 0) { return -1; }
    read_line(f); vv_n = 0;
    cols = malloc(20);
    while (true) {
        if (read_line(f) == 0) { break; }
        n = parse_row(cols);
        vv_tid[vv_n] = atoi(row_buf + cols[1]);
        vv_pid[vv_n] = atoi(row_buf + cols[2]);
        vv_date[vv_n] = save_col(cols[3]);
        vv_mark[vv_n] = atoi(row_buf + cols[4]);
        vv_n = vv_n + 1;
    }
    fclose(f); free(cols); return vv_n;
