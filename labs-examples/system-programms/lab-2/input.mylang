// ===================== String buffer =====================
global buf of string = "                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  ";
global tmp of string = "                                                                                                                                                                                                                                                                                                                                ";
global tmp2 of string = "                                                                                                                                                                                                                                                                ";
global buf_off of int = 0;

def alloc_buf() of int {
    r = buf_off;
    buf_off = buf_off + 256;
    return r;
}

// ===================== int to string =====================
def int_to_str(dst of string, val of int) of int {
    s = buf_off;
    off = alloc_buf();
    i = 0;
    if (val == 0) {
        buf[off] = 48;
        i = 1;
    } else {
        v = val;
        while (v > 0) {
            buf[off + i] = (v % 10) + 48;
            v = v / 10;
            i = i + 1;
        }
    }
    j = 0;
    while (i > 0) {
        i = i - 1;
        dst[j] = buf[off + i];
        j = j + 1;
    }
    dst[j] = 0;
    buf_off = s;
    return j;
}

// ===================== Pipe =====================
struct Pipe {
    buf of int[256];
    head of int;
    tail of int;
    count of int;
    done of int;
}

def pipe_init(p of Pipe) {
    p.head = 0;
    p.tail = 0;
    p.count = 0;
    p.done = 0;
}

def pipe_write(p of Pipe, v of int) of int {
    if (p.count < 256) {
        p.buf[p.tail] = v;
        p.tail = (p.tail + 1) % 256;
        p.count = p.count + 1;
        return 0;
    }
    return -2;
}

def pipe_read(p of Pipe) of int {
    if (p.done == 1 && p.count <= 0) { return -1; }
    if (p.count > 0) {
        r = p.buf[p.head];
        p.head = (p.head + 1) % 256;
        p.count = p.count - 1;
        return r;
    }
    return -2;
}

def pipe_close(p of Pipe) { p.done = 1; }

// ===================== CSV utilities =====================
def read_line_from_buf(src of string, pos of int, dst of int) of int {
    i = 0;
    while (true) {
        c = src[pos + i];
        if (c == 0 || c == 10) {
            buf[dst + i] = 0;
            if (c == 10) { return pos + i + 1; }
            return -1;
        }
        buf[dst + i] = c;
        i = i + 1;
    }
}

def csv_field(dst of string, src of string, pos of int) of int {
    i = 0;
    while (true) {
        c = src[pos + i];
        if (c == 0 || c == 10 || c == 13 || c == ',') {
            dst[i] = 0;
            if (c == 13 && src[pos + i + 1] == 10) { return pos + i + 2; }
            if (c == ',') { return pos + i + 1; }
            return pos + i;
        }
        dst[i] = c;
        i = i + 1;
    }
}

// ===================== Load CSV into buffer =====================
def load_csv(path of string) of int {
    f = fopen(path, "r");
    off = buf_off;
    while (true) {
        c = fgetc(f);
        if (c < 0) {
            buf[buf_off] = 0;
            buf_off = buf_off + 1;
            fclose(f);
            return off;
        }
        buf[buf_off] = c;
        buf_off = buf_off + 1;
    }
}

// ===================== People struct =====================
struct Person {
    id of int;
    surname of int;
    name of int;
    patronymic of int;
    birthday of int;
}
global people of Person[32];
global people_count of int = 0;

// ===================== Pipes =====================
global p_line of Pipe;
global p_join of Pipe;
global p_result of Pipe;

// ===================== CSV data buffers =====================
global csv_vedomosti of string = 0;
global csv_types_ved of string = 0;
global csv_people of string = 0;
global csv_studies of string = 0;
global csv_students of string = 0;
global csv_group_plans of string = 0;

// ===================== Per-query globals =====================
global s_nzk of int[32];
global s_person of int[32];
global s_count of int = 0;
global plan_ids of int[16];
global plan_counts of int[16];
global plan_total of int = 0;
global g4100_ids of int[16];
global g4100_count of int = 0;
global g1100_ids of int[16];
global g1100_count of int = 0;
global g4100_sum of int[16];
global g4100_n of int[16];
global g1100_sum of int;
global g1100_n of int;
global zaoch_ids of int[32];
global zaoch_count of int = 0;
