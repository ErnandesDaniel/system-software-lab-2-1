// Q2: LEFT JOIN people + studies + students
// =============================================================
def q2_scan() of int
    i = 0
    while i < 31 {
        if strcmp(p_surname[i], "РЃР»РєРёРЅ") > 0 then {
            if p_id[i] == 163276 then {
                j = 0
                while j < 30 {
                    if o_person_id[j] == 163276 then {
                        k = 0
                        while k < 30 {
                            if st_person_id[k] == 163276 then {
                                if strcmp(st_start[k], "2008-09-01") == 0 then {
                                    puts("=== Query 2: LEFT JOIN ===")
                                    buf_clear(buf)
                                    int_to_str(buf, p_id[i])
                                    strcat(buf, ", ")
                                    strcat(buf, o_nzk[j])
                                    strcat(buf, ", ")
                                    strcat(buf, "163276")
                                    puts(buf)
                                    k = 30; j = 30; i = 31
                                }
                            }
                            k = k + 1
                        }
                    }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    return 0
end

def run_q2() of int
    q2_scan()
    return 0
end

