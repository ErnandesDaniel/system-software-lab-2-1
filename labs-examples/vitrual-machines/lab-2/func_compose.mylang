// Пример композиции функций через переменные первого класса
// Функция присваивается переменной и применяется несколько раз

extern puts

def main() of int
    puts("Testing function composition:");

    double = def double_impl(x of int) of int
        return x * 2
    end

    return double(double(3))  // 3*2=6, 6*2=12
end
