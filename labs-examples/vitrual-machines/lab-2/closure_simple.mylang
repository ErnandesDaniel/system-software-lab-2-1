// Пример замыкания: вложенная функция захватывает переменную из внешней функции
// inner захватывает x из main

extern puts

def main() of int
    x = 10;

    puts("Testing closure (capture read-only):");

    def inner() of int
        return x   // x захвачен из внешнего scope
    end

    return inner()  // 10
end
