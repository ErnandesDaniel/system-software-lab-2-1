import getchar
import putchar
import malloc

def streq_at(buf of string, start of int, s of string) of int
    i = 0
    while 1 == 1 {
        ca = buf[start + i]
        cb = s[i]
        if ca != cb then { return 0 }
        if ca == 0 then { return 1 }
        i = i + 1
    }
end

def putstr(s of string)
    i = 0
    while 1 == 1 {
        c = s[i]
        if c == 0 then { return }
        putchar(c)
        i = i + 1
    }
end

def main() of int
    buf = malloc(20)
    buf[0] = 101
    buf[1] = 120
    buf[2] = 105
    buf[3] = 116
    buf[4] = 0

    if streq_at(buf, 0, "exit") == 1 then {
        putstr(buf)
    }
    return 0
end
