extern puts
extern putchar
extern sleep

def print_once()
    while 1 == 1 {
        putchar(49)
        sleep(1)
    }
    loop_end
end

def print_two()
    while 1 == 1 {
        putchar(50)
        sleep(1)
    }
    loop_end
