extern def puts(s of string) end
extern def putchar(c of int) of int end
extern def sleep(seconds of int) end

def print_ones()
    while 1 == 1 {
        putchar(49)
        sleep(1)
    }
    loop_end
end

def print_twos()
    while 1 == 1 {
        putchar(50)
        sleep(1)
    }
    loop_end
end

def main()
