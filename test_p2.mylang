def load_people() of int
    f = fopen("csv-data/people.csv", "r")
    if f == "" then return 1 end
    fgets(buf, 256, f)
    p_count = 0
    while feof(f) == 0 {
        fgets(buf, 256, f)
        if feof(f) != 0 then break end
        pos = 0
        p_count = p_count + 1
    }
    fclose(f)
    return 0
end

