extern fopen
extern fclose
extern fgets
extern feof

global buf of string = "                                                                                                                                                                                                                                ";
global p_count of int = 0;

def load_people() of int
    f = fopen("test.csv", "r")
    if f == "" then return 1 end
    fgets(buf, 256, f)
    p_count = 0
    while feof(f) == 0 {
        fgets(buf, 256, f)
        p_count = p_count + 1
    }
    fclose(f)
    return 0
end

def main() of int
    puts("ok")
    return 0
end