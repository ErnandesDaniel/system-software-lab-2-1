// Математические функции для WebAssembly

def factorial(n of int) of int
    result = 1;
    i = 1;
    while i <= n loop
        result = result * i;
        i = i + 1;
    end
    return result;
end

def power(base of int, exp of int) of int
    result = 1;
    while exp > 0 loop
        result = result * base;
        exp = exp - 1;
    end
    return result;
end

def sum(a of int, b of int) of int
    return a + b;
end

def diff(a of int, b of int) of int
    return a - b;
end

def product(a of int, b of int) of int
    return a * b;
end