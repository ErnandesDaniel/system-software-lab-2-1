// ===================== String buffer =====================
global buf of string;
global buf_off of int = 0;

// ===================== Global data arrays =====================
// People: id, surname, name, patronymic, birthday
global p_id of int[100]; global p_surname of int[100]; global p_name of int[100];
global p_patr of int[100]; global p_bday of int[100]; global p_count of int = 0;

// Studies: id, student_id, plan_id, course, group_name
global s_id of int[100]; global s_student of int[100]; global s_plan of int[100];
global s_course of int[100]; global s_group of int[100]; global s_count of int = 0;

// Students: id, person_id, nzk
global st_id of int[100]; global st_person of int[100]; global st_nzk of int[100]; global st_count of int = 0;

// Vedomosti: id, study_id, type_id, date_str, grade
