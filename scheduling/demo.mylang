// scheduling/demo.mylang — минимальная демонстрация корутин

extern puts
extern run_scheduler

coroutine worker1() of int
    puts("1");
    yield;
    puts("2");
    yield;
    puts("3");
    return 0;
end

coroutine worker2() of int
    puts("A");
    yield;
    puts("B");
    return 0;
end

def main() of int
begin
    puts("Scheduler start");
    run_scheduler();
    puts("Scheduler done");
    return 0;
end
end
