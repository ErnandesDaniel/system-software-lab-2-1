extern fopen
extern fclose
extern fgets
extern feof
extern puts
extern strcmp

global buf of string = "                                                                                                                                                                                                                                ";

def main() of int
    puts("open")
    f = fopen("labs-examples/system-programms/lab-2/csv-data/people.csv", "r")
    if f == "" then puts("FAIL") else puts("OK") end
    if f != "" then
        fgets(buf, 256, f)
        puts(buf)
        fgets(buf, 256, f)
        puts(buf)
        fclose(f)
    end
    return 0
end