extern fopen
extern fclose
extern fgets
extern feof
extern puts
extern malloc

def main() of int
    puts("start")
    b = malloc(64)
    f = fopen("labs-examples/system-programms/lab-2/csv-data/people.csv", "r")
    if f != "" then
        fgets(b, 64, f)
        puts(b)
        fclose(f)
    end
    puts("done")
    return 0
end